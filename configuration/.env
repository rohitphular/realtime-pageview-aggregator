# Kafka broker credentials
KAFKA_ADMIN_USERNAME=admin
KAFKA_ADMIN_PASSWORD=admin-secret

# Kafka producer credentials (used by pageview-data-producer)
KAFKA_PRODUCER_USERNAME=producer
KAFKA_PRODUCER_PASSWORD=producer-secret
KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN

# Kafka Flink consumer credentials (used by pageview-stream-processor)
KAFKA_FLINK_USERNAME=flink
KAFKA_FLINK_PASSWORD=flink-secret

# Schema Registry
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Grafana
GF_ADMIN_PASSWORD=admin-local
