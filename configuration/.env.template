# Copy this file and fill in the values:
#   cp configuration/.env.template configuration/.env

# Kafka broker credentials
KAFKA_ADMIN_USERNAME=<your-admin-username>
KAFKA_ADMIN_PASSWORD=<your-admin-password>

# Kafka producer credentials (used by pageview-data-producer)
KAFKA_PRODUCER_USERNAME=<your-producer-username>
KAFKA_PRODUCER_PASSWORD=<your-producer-password>
KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN

# Kafka Flink consumer credentials (used by pageview-stream-processor)
KAFKA_FLINK_USERNAME=<your-flink-username>
KAFKA_FLINK_PASSWORD=<your-flink-password>

# Grafana
GF_ADMIN_PASSWORD=<your-grafana-password>
